# 镜像地址
IIOT_REGISTRY=registry.example.com
IIOT_HTTPAPI_IMAGE=registry.example.com/iiot/iiot-httpapi:latest
IIOT_WEB_IMAGE=registry.example.com/iiot/iiot-web:latest
IIOT_MIGRATION_IMAGE=registry.example.com/iiot/iiot-migrationworkapp:latest
IIOT_DATAWORKER_IMAGE=registry.example.com/iiot/iiot-dataworker:latest
IIOT_NGINX_IMAGE=registry.example.com/library/nginx:alpine
IIOT_POSTGRES_IMAGE=registry.example.com/library/timescaledb:latest-pg17
IIOT_REDIS_IMAGE=registry.example.com/library/redis:7.4-alpine
IIOT_RABBITMQ_IMAGE=registry.example.com/library/rabbitmq:3-management-alpine
IIOT_DASHBOARD_IMAGE=registry.example.com/library/aspire-dashboard:9.0

# 基础凭据（请通过 secrets 或受控环境变量注入真实值）
PG_PASSWORD=change-me-postgres-password
RABBITMQ_DEFAULT_USER=iiot
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq-password
ASPIRE_DASHBOARD_FRONTEND_BROWSERTOKEN=change-me-dashboard-browser-token
ASPIRE_DASHBOARD_OTLP_PRIMARYAPIKEY=change-me-dashboard-otlp-api-key

# 网关与 TLS
GATEWAY_HTTP_PORT=80
GATEWAY_HTTPS_PORT=443
SERVER_IP=iiot.example.com
TLS_CERT_FILE=./certs/tls.crt
TLS_KEY_FILE=./certs/tls.key

# 集群规模
HTTPAPI_REPLICAS=3
WEB_REPLICAS=2

# Forwarded headers trusted reverse proxies
FORWARDED_HEADERS_ENABLED=true
FORWARDED_HEADERS_FORWARDLIMIT=2
FORWARDED_HEADERS_KNOWNNETWORKS__0=172.16.0.0/12
FORWARDED_HEADERS_KNOWNNETWORKS__1=10.0.0.0/8
