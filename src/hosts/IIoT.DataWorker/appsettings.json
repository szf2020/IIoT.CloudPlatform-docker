{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "DistributedLock": {
    "LeaseSeconds": 120,
    "RenewalCadenceSeconds": 30
  },
  "CacheSafety": {
    "FailSafeMinutes": 30
  },
  "Consumers": {
    "PassStationConcurrentMessageLimit": 4,
    "DeviceLogConcurrentMessageLimit": 3,
    "HourlyCapacityConcurrentMessageLimit": 1
  }
}
