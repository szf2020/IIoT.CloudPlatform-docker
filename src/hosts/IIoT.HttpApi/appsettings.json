{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "",
    "ExpiryMinutes": 60,
    "Issuer": "IIoT.CloudPlatform",
    "Audience": "IIoT.WpfClient"
  },
  "PermissionCache": {
    "KeyPrefix": "iiot:permissions:v1:",
    "ExpirationMinutes": 10
  },
  "DistributedLock": {
    "LeaseSeconds": 120,
    "RenewalCadenceSeconds": 30
  },
  "CacheSafety": {
    "FailSafeMinutes": 30
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 120,
      "QueueLimit": 0,
      "WindowSeconds": 60
    },
    "Login": {
      "PermitLimit": 5,
      "QueueLimit": 0,
      "WindowSeconds": 60
    },
    "Bootstrap": {
      "PermitLimit": 10,
      "QueueLimit": 0,
      "WindowSeconds": 60
    },
    "EdgeUpload": {
      "TokenLimit": 30,
      "TokensPerPeriod": 30,
      "QueueLimit": 0,
      "ReplenishmentPeriodSeconds": 60
    }
  }
}
